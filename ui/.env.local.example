# ─────────────────────────────────────────────────────────────────────────────
# ENStop — Local development environment template
# Copy this file to .env.local and fill in your values.
# .env.local is git-ignored and never committed.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase ─────────────────────────────────────────────────────────────────
# Local Supabase CLI instance (default ports). For production, use the values
# from your Supabase project dashboard → Settings → API.
VITE_SUPABASE_URL=http://localhost:54321
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Imxvd2NhbCIsInJvbGUiOiJhbm9uIiwiaWF0IjoxNzg5Nzc2MDAwLCJleHAiOjIxMDUzNzYwMDB9.dummy_anon_key_for_local_cli

# ── Dev flags ─────────────────────────────────────────────────────────────────
VITE_ENV=local
# Set to true to activate MSW mock handlers instead of live Supabase queries.
VITE_USE_MOCKS=false

# ─────────────────────────────────────────────────────────────────────────────
# Anti-scraping / Edge Function variables (Phase 2)
# Leave these blank for local development — the app detects their absence and
# bypasses the Turnstile challenge gate automatically.
# See TODO.md for instructions on where to obtain these values.
# ─────────────────────────────────────────────────────────────────────────────

# Cloudflare Turnstile — site key (public, safe to expose in frontend code).
# Source: Cloudflare Dashboard → Turnstile → your site → Site Key
VITE_TURNSTILE_SITE_KEY=

# Supabase Edge Function secret (server-side only — set in Supabase Secrets,
# NOT here). Listed for documentation purposes; Vite never reads this.
# SUPABASE_SERVICE_ROLE_KEY=  ← set via: supabase secrets set SUPABASE_SERVICE_ROLE_KEY=...
# TURNSTILE_SECRET=           ← set via: supabase secrets set TURNSTILE_SECRET=...
