# ─────────────────────────────────────────────────────────────────────────────
# ENStop — External dev environment (vite --mode dev)
#
# Loaded during: npm run dev:external
# Points the app at a remote (non-production) Supabase instance.
# Copy this file and fill in real dev credentials — never commit secrets.
# ─────────────────────────────────────────────────────────────────────────────

# MSW mock layer — disabled, real dev backend is used.
VITE_USE_MOCKS=false

# Remote dev Supabase project — replace with actual dev project values.
# Source: Supabase Dashboard → Settings → API
VITE_SUPABASE_URL=https://your-dev-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-dev-anon-key

# Turnstile — leave blank to bypass the challenge gate in dev.
VITE_TURNSTILE_SITE_KEY=
