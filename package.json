{
  "name": "enstop-root",
  "private": true,
  "workspaces": [
    "ui"
  ],
  "scripts": {
    "dev": "npm --prefix ui run dev",
    "dev:mock": "npm --prefix ui run dev:mock",
    "dev:local": "./scripts/dev-local.sh",
    "build": "npm --prefix ui run build && cp -r ui/dist ./dist",
    "build:mock": "npm --prefix ui run build:mock && cp -r ui/dist ./dist",
    "preview": "npm --prefix ui run preview",
    "test": "npm --prefix ui run test",
    "test:watch": "npm --prefix ui run test:watch",
    "test:e2e": "npm --prefix ui run test:e2e",
    "db:start": "supabase start",
    "db:stop": "supabase stop",
    "db:reset": "supabase db reset",
    "db:diff": "supabase db diff",
    "db:push": "supabase db push",
    "db:types": "supabase gen types typescript --local > ui/src/types/supabase-generated.ts",
    "db:studio": "supabase studio",
    "lint": "npm --prefix ui run lint",
    "lint:fix": "npm --prefix ui run lint:fix",
    "format": "npm --prefix ui run format",
    "format:check": "npm --prefix ui run format:check",
    "typecheck": "npm --prefix ui run typecheck"
  },
  "devDependencies": {
    "supabase": "^2.107.0"
  }
}
